{
    "name": "@codeagent/mcp-server",
    "version": "0.0.1",
    "description": "MCP server for CodeAgent with tool registration and resource handling",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "codeagent-mcp": "./dist/cli.js"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@codeagent/core-types": "workspace:*",
        "@codeagent/graph-store": "workspace:*",
        "@codeagent/ingestion-pipeline": "workspace:*",
        "@modelcontextprotocol/sdk": "^1.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "typescript": "^5.4.5",
        "vitest": "^1.6.0"
    }
}