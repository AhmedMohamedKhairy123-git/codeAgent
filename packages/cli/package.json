{
    "name": "@codeinsight/cli",
    "version": "0.1.0",
    "description": "CLI tool for CodeInsight with analyze, status, list, and clean commands",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "codeinsight": "./dist/cli.js"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@codeinsight/core-types": "workspace:*",
        "@codeinsight/graph-store": "workspace:*",
        "@codeinsight/fs-walker": "workspace:*",
        "@codeinsight/ingestion-pipeline": "workspace:*",
        "@codeinsight/mcp-server": "workspace:*",
        "commander": "^12.0.0",
        "chalk": "^5.3.0",
        "cli-progress": "^3.12.0",
        "ora": "^8.0.0"
    },
    "devDependencies": {
        "@types/cli-progress": "^3.11.5",
        "@types/node": "^20.0.0",
        "typescript": "^5.4.5",
        "vitest": "^1.6.0"
    }
}