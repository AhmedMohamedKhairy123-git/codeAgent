{
    "name": "@codeagent/call-graph",
    "version": "0.0.1",
    "description": "Call graph builder with relationship extraction and confidence scoring for CodeAgent",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@codeagent/core-types": "workspace:*",
        "@codeagent/ast-extractor": "workspace:*",
        "@codeagent/import-resolver": "workspace:*",
        "@codeagent/graph-store": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.4.5",
        "vitest": "^1.6.0"
    }
}