{
    "name": "@codeagent/core-types",
    "version": "0.0.1",
    "description": "Shared type definitions for CodeAgent",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "typescript": "^5.4.5"
    },
    "peerDependencies": {
        "typescript": ">=5.0.0"
    }
}