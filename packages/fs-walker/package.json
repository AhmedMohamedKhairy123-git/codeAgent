{
    "name": "@codeagent/fs-walker",
    "version": "0.0.1",
    "description": "File system walker with ignore pattern support for CodeAgent",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@codeagent/core-types": "workspace:*",
        "ignore": "^5.3.1"
    },
    "devDependencies": {
        "@types/ignore": "^5.3.1",
        "typescript": "^5.4.5",
        "vitest": "^1.6.0"
    }
}