import type { GraphNode, GraphEdge } from '@codeagent/core-types';

// Community node
export interface Community {
    id: string;
    label: string;
    heuristicLabel: string;
    cohesion: number;
    symbolCount: number;
    members: string[];
    keywords?: string[];
    description?: string;
}

// Community detection result
export interface CommunityResult {
